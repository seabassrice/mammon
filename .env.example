# ── Vercel Postgres (Neon) ──────────────────────────────────────────
# These are set automatically by Vercel when you provision Postgres.
# For local development, copy .env.example → .env.local and fill in
# values from your Vercel dashboard → Storage → Postgres → .env.local.
#
#   POSTGRES_URL                  postgres://…
#   POSTGRES_URL_NON_POOLING      postgres://…
#   POSTGRES_USER                 …
#   POSTGRES_HOST                 …
#   POSTGRES_PASSWORD             …
#   POSTGRES_DATABASE             …
#
# Get them from: https://vercel.com/dashboard → Storage → [your-db]

# ── Better Auth ──────────────────────────────────────────────────────
# Required: a long random string used to sign/verify session tokens.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# The canonical URL of your app (no trailing slash).
#   Local dev:    http://localhost:3000
#   Production:   https://your-app.vercel.app
BETTER_AUTH_URL=

# Public URL exposed to the browser (same value as BETTER_AUTH_URL).
NEXT_PUBLIC_BETTER_AUTH_URL=